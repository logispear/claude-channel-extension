{
  "manifest_version": 3,
  "name": "Claude Code",
  "version": "1.0.0",
  "description": "Chat with Claude Code from any webpage via a side panel",
  "permissions": ["sidePanel", "activeTab", "storage", "scripting"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "Open Channel"
  },
  "options_ui": {
    "page": "settings.html",
    "open_in_tab": false
  },
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "http://127.0.0.1:*/*",
    "http://localhost:*/*",
    "<all_urls>"
  ]
}
